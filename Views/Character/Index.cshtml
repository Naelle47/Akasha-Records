@model AkashaRecords.Models.ViewModels.CharacterFiltersVM
@using AkashaRecords.Helpers

@{
    ViewData["Title"] = "Personnages";
    var letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".ToCharArray();
    var allRarityClass = "filter-chip rarity-chip" + (Model.Rarity is null ? " active" : "");
    var rarity4Class = "filter-chip rarity-chip" + (Model.Rarity == 4 ? " active" : "");
    var rarity5Class = "filter-chip rarity-chip" + (Model.Rarity == 5 ? " active" : "");
    var allLetterClass = "filter-chip" + (Model.Letter is null ? " active" : "");
    var allElementClass = "filter-chip" + (Model.ElementId is null ? " active" : "");
    var allWeaponTypeClass = "filter-chip" + (Model.WeaponTypeId is null ? " active" : "");
    var allRegionClass = "filter-chip" + (Model.RegionId is null ? " active" : "");
}

<div class="characters-page">

    <div class="characters-header">
        <h1>Personnages</h1>
        <p>@Model.Characters.Count personnage(s) affiché(s)</p>
    </div>

    <form asp-action="Index" method="get" class="search-form">
        <input type="hidden" name="elementId" value="@Model.ElementId" />
        <input type="hidden" name="weaponTypeId" value="@Model.WeaponTypeId" />
        <input type="hidden" name="regionId" value="@Model.RegionId" />
        <input type="hidden" name="rarity" value="@Model.Rarity" />
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text"
                   name="search"
                   value="@Model.Search"
                   placeholder="Rechercher un personnage..."
                   class="search-input"
                   autocomplete="off" />
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index"
                       asp-route-elementId="@Model.ElementId"
                       asp-route-weaponTypeId="@Model.WeaponTypeId"
                       asp-route-regionId="@Model.RegionId"
                       asp-route-rarity="@Model.Rarity"
                       class="search-clear">
                    <i class="fa-solid fa-xmark"></i>
                </a>
            }
        </div>
    </form>

    <div class="alpha-nav">
        <a asp-action="Index"
           asp-route-elementId="@Model.ElementId"
           asp-route-weaponTypeId="@Model.WeaponTypeId"
           asp-route-regionId="@Model.RegionId"
           asp-route-rarity="@Model.Rarity"
           asp-route-letter=""
           class="@allLetterClass">*</a>
        @foreach (var l in letters)
        {
            var lClass = "filter-chip" + (Model.Letter == l.ToString() ? " active" : "");
            <a asp-action="Index"
               asp-route-elementId="@Model.ElementId"
               asp-route-weaponTypeId="@Model.WeaponTypeId"
               asp-route-regionId="@Model.RegionId"
               asp-route-rarity="@Model.Rarity"
               asp-route-letter="@l"
               class="@lClass">@l</a>
        }
    </div>

    <section class="character-filters">

        <div class="filter-row">
            <span class="filter-label">Rareté</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-elementId="@Model.ElementId"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-regionId="@Model.RegionId"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity=""
                   class="@allRarityClass">*</a>
                <a asp-action="Index"
                   asp-route-elementId="@Model.ElementId"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-regionId="@Model.RegionId"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity="4"
                   class="@rarity4Class">4✦</a>
                <a asp-action="Index"
                   asp-route-elementId="@Model.ElementId"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-regionId="@Model.RegionId"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity="5"
                   class="@rarity5Class">5✦</a>
            </div>
        </div>

        <div class="filter-row">
            <span class="filter-label">Élément</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-elementId=""
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-regionId="@Model.RegionId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   class="@allElementClass">*</a>
                @foreach (var e in Model.Elements)
                {
                    var eClass = "filter-chip" + (Model.ElementId == e.Id ? " active" : "");
                    <a asp-action="Index"
                           asp-route-elementId="@e.Id"
                           asp-route-weaponTypeId="@Model.WeaponTypeId"
                           asp-route-regionId="@Model.RegionId"
                           asp-route-rarity="@Model.Rarity"
                           asp-route-letter="@Model.Letter"
                           class="@eClass">
                        <img src="@ImageHelper.ElementIcon(e.IconUrl)" alt="@e.Name" class="filter-icon" />
                    </a>
                }
            </div>
        </div>

        <div class="filter-row">
            <span class="filter-label">Arme</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-elementId="@Model.ElementId"
                   asp-route-weaponTypeId=""
                   asp-route-regionId="@Model.RegionId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   class="@allWeaponTypeClass">*</a>
                @foreach (var w in Model.WeaponTypes)
                {
                    var wClass = "filter-chip" + (Model.WeaponTypeId == w.Id ? " active" : "");
                    <a asp-action="Index"
                           asp-route-elementId="@Model.ElementId"
                           asp-route-weaponTypeId="@w.Id"
                           asp-route-regionId="@Model.RegionId"
                           asp-route-rarity="@Model.Rarity"
                           asp-route-letter="@Model.Letter"
                           class="@wClass">
                        <img src="@ImageHelper.WeaponTypeIcon(w.IconUrl)" alt="@w.Name" class="filter-icon" />
                    </a>
                }
            </div>
        </div>

        <div class="filter-row">
            <span class="filter-label">Région</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-elementId="@Model.ElementId"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-regionId=""
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   class="@allRegionClass">*</a>
                @foreach (var r in Model.Regions)
                {
                    var rClass = "filter-chip" + (Model.RegionId == r.Id ? " active" : "");
                    <a asp-action="Index"
                           asp-route-elementId="@Model.ElementId"
                           asp-route-weaponTypeId="@Model.WeaponTypeId"
                           asp-route-regionId="@r.Id"
                           asp-route-rarity="@Model.Rarity"
                           asp-route-letter="@Model.Letter"
                           class="@rClass">
                        <img src="@ImageHelper.RegionIcon(r.IconUrl)" alt="@r.Name" class="filter-icon" />
                    </a>
                }
            </div>
        </div>

    </section>

    <div class="characters-grid">
        @foreach (var c in Model.Characters)
        {
            var rarityClass = "rarity-badge " + (c.Rarity == 5 ? "rarity-5" : "rarity-4");
            <article class="character-card">
                <img src="@ImageHelper.CharacterIcon(c.IconUrl)"
                     alt="@c.Name"
                     class="character-card-image" />

                <div class="character-card-body">
                    <div>
                        <h2 class="character-name">@c.Name</h2>
                        <div class="character-fields">

                            <div class="field-row">
                                <span class="field-label">Rareté</span>
                                <span class="field-value">
                                    <span class="@rarityClass">
                                        @CharacterHelper.RarityStars(c.Rarity)
                                    </span>
                                </span>
                            </div>

                            <div class="field-row">
                                <span class="field-label">Élément</span>
                                <span class="field-value">
                                    @if (c.Element != null)
                                    {
                                        <img src="@ImageHelper.ElementIcon(c.Element.IconUrl)"
                                             alt="@c.Element.Name" class="filter-icon" />
                                        @c.Element.Name
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                </span>
                            </div>

                            <div class="field-row">
                                <span class="field-label">Arme</span>
                                <span class="field-value">
                                    @if (c.WeaponType != null)
                                    {
                                        <img src="@ImageHelper.WeaponTypeIcon(c.WeaponType.IconUrl)"
                                             alt="@c.WeaponType.Name" class="filter-icon" />
                                        @c.WeaponType.Name
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                </span>
                            </div>

                            <div class="field-row">
                                <span class="field-label">Région</span>
                                <span class="field-value">
                                    @if (c.Region != null)
                                    {
                                        <img src="@ImageHelper.RegionIcon(c.Region.IconUrl)"
                                             alt="@c.Region.Name" class="filter-icon" />
                                        @c.Region.Name
                                    }
                                    else
                                    {
                                        <span>N/A</span>
                                    }
                                </span>
                            </div>

                            <div class="field-row">
                                <span class="field-label">Sortie</span>
                                <span class="field-value">
                                    @CharacterHelper.FormatReleaseDate(c.ReleaseDate)
                                </span>
                            </div>

                        </div>
                    </div>

                    <div class="character-card-footer">
                        <a asp-controller="Character"
                               asp-action="Details"
                               asp-route-id="@c.Id"
                               class="btn-primary-sm">
                            Voir la fiche
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>

</div>