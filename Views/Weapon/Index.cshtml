@model AkashaRecords.Models.ViewModels.WeaponFiltersVM
@using AkashaRecords.Helpers

@{
    ViewData["Title"] = "Armes";

    var letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ".ToCharArray();
    var allLetterClass = "filter-chip" + (Model.Letter is null ? " active" : "");
    var allRarityClass = "filter-chip rarity-chip" + (Model.Rarity is null ? " active" : "");
    var rarity4Class = "filter-chip rarity-chip" + (Model.Rarity == 4 ? " active" : "");
    var rarity5Class = "filter-chip rarity-chip" + (Model.Rarity == 5 ? " active" : "");
    var allSourceClass = "filter-chip rarity-chip" + (Model.Source is null ? " active" : "");
    var allWeaponTypeClass = "filter-chip" + (Model.WeaponTypeId is null ? " active" : "");
}

<div class="characters-page">

    <div class="characters-header">
        <h1>Armes</h1>
        <p>@Model.Weapons.Count arme(s) affichée(s)</p>
    </div>

    <form asp-action="Index" method="get" class="search-form">
        <input type="hidden" name="weaponTypeId" value="@Model.WeaponTypeId" />
        <input type="hidden" name="rarity" value="@Model.Rarity" />
        <input type="hidden" name="source" value="@Model.Source" />
        <div class="search-bar">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input type="text"
                   name="search"
                   value="@Model.Search"
                   placeholder="Rechercher une arme..."
                   class="search-input"
                   autocomplete="off" />
            @if (!string.IsNullOrEmpty(Model.Search))
            {
                <a asp-action="Index"
                       asp-route-weaponTypeId="@Model.WeaponTypeId"
                       asp-route-rarity="@Model.Rarity"
                       asp-route-source="@Model.Source"
                       class="search-clear">
                    <i class="fa-solid fa-xmark"></i>
                </a>
            }
        </div>
    </form>

    <div class="alpha-nav">
        <a asp-action="Index"
           asp-route-weaponTypeId="@Model.WeaponTypeId"
           asp-route-rarity="@Model.Rarity"
           asp-route-source="@Model.Source"
           asp-route-letter=""
           class="@allLetterClass">*</a>

        @foreach (var l in letters)
        {
            var lClass = "filter-chip" + (Model.Letter == l.ToString() ? " active" : "");
            <a asp-action="Index"
               asp-route-weaponTypeId="@Model.WeaponTypeId"
               asp-route-rarity="@Model.Rarity"
               asp-route-source="@Model.Source"
               asp-route-letter="@l"
               class="@lClass">@l</a>
        }
    </div>

    <section class="character-filters">

        <div class="filter-row">
            <span class="filter-label">Rareté</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-source="@Model.Source"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity=""
                   class="@allRarityClass">*</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-source="@Model.Source"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity="4"
                   class="@rarity4Class">4✦</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-source="@Model.Source"
                   asp-route-letter="@Model.Letter"
                   asp-route-rarity="5"
                   class="@rarity5Class">5✦</a>
            </div>
        </div>

        <div class="filter-row">
            <span class="filter-label">Source</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   asp-route-source=""
                   class="@allSourceClass">*</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   asp-route-source="battle_pass"
                   class="filter-chip rarity-chip @(Model.Source == "battle_pass" ? " active" : "")">Pass</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   asp-route-source="fishing"
                   class="filter-chip rarity-chip @(Model.Source == "fishing" ? " active" : "")">Pêche</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   asp-route-source="craft"
                   class="filter-chip rarity-chip @(Model.Source == "craft" ? " active" : "")">Craft</a>

                <a asp-action="Index"
                   asp-route-weaponTypeId="@Model.WeaponTypeId"
                   asp-route-rarity="@Model.Rarity"
                   asp-route-letter="@Model.Letter"
                   asp-route-source="event"
                   class="filter-chip rarity-chip @(Model.Source == "event" ? " active" : "")">Événement</a>
            </div>
        </div>

        <div class="filter-row">
            <span class="filter-label">Type</span>
            <div class="filter-chips">
                <a asp-action="Index"
                   asp-route-weaponTypeId=""
                   asp-route-rarity="@Model.Rarity"
                   asp-route-source="@Model.Source"
                   asp-route-letter="@Model.Letter"
                   class="@allWeaponTypeClass">*</a>

                @foreach (var wt in Model.WeaponTypes)
                {
                    var wtClass = "filter-chip" + (Model.WeaponTypeId == wt.Id ? " active" : "");
                    <a asp-action="Index"
                           asp-route-weaponTypeId="@wt.Id"
                           asp-route-rarity="@Model.Rarity"
                           asp-route-source="@Model.Source"
                           asp-route-letter="@Model.Letter"
                           class="@wtClass">
                        <img src="@ImageHelper.WeaponTypeIcon(wt.IconUrl)" alt="@wt.Name" class="filter-icon" />
                    </a>
                }
            </div>
        </div>

    </section>

    <div class="weapons-grid">
        @foreach (var w in Model.Weapons)
        {
            <article class="weapon-card">
                <img src="@ImageHelper.WeaponIcon(w.IconUrl)"
                     alt="@w.Name"
                     class="weapon-card-image" />

                <div class="weapon-card-body">
                    <div>
                        <h2 class="weapon-name">@w.Name</h2>
                        <div class="character-fields">

                            <div class="field-row">
                                <span class="field-label">Rareté</span>
                                <span class="field-value">
                                    <span class="rarity-badge @(w.Rarity == 5 ? "rarity-5" : w.Rarity == 4 ? "rarity-4" : "rarity-3")">
                                        @CharacterHelper.RarityStars(w.Rarity)
                                    </span>
                                </span>
                            </div>

                            <div class="field-row">
                                <span class="field-label">Type</span>
                                <span class="field-value">
                                    @if (w.WeaponType != null)
                                    {
                                        <img src="@ImageHelper.WeaponTypeIcon(w.WeaponType.IconUrl)"
                                             alt="@w.WeaponType.Name" class="filter-icon" />
                                        @w.WeaponType.Name
                                    }
                                </span>
                            </div>

                            @if (!string.IsNullOrEmpty(w.Series))
                            {
                                <div class="field-row">
                                    <span class="field-label">Série</span>
                                    <span class="field-value">@w.Series</span>
                                </div>
                            }

                        </div>
                    </div>

                    <div class="character-card-footer">
                        <a asp-controller="Weapon"
                               asp-action="Details"
                               asp-route-id="@w.Id"
                               class="btn-primary-sm">
                            Voir la fiche
                        </a>
                    </div>
                </div>
            </article>
        }
    </div>

</div>